---
import { company } from "~/data/company";

interface Props {
  values?: Record<string, string>;
  errors?: Record<string, string>;
}

const { values = {}, errors = {} } = Astro.props;
---

<section id="quote" class="bg-slate-100">
  <div class="mx-auto max-w-3xl px-4 py-16">
    <h2 class="text-3xl font-bold text-ink">Request a free quote</h2>
    <p class="mt-2 text-slate-600">
      Tell us about your project and we'll follow up within one business day.
    </p>

    <form method="POST" action="/api/quote" class="mt-8 grid gap-5 rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="name" class="field-label">Full name</label>
          <input id="name" name="name" type="text" required autocomplete="name" value={values.name ?? ""} class="field" />
          {errors.name && <p class="mt-1 text-sm text-brand">{errors.name}</p>}
        </div>
        <div>
          <label for="phone" class="field-label">Phone</label>
          <input id="phone" name="phone" type="tel" required autocomplete="tel" pattern="[0-9 +()\-]{7,}" value={values.phone ?? ""} class="field" />
          {errors.phone && <p class="mt-1 text-sm text-brand">{errors.phone}</p>}
        </div>
      </div>

      <div>
        <label for="email" class="field-label">Email</label>
        <input id="email" name="email" type="email" required autocomplete="email" value={values.email ?? ""} class="field" />
        {errors.email && <p class="mt-1 text-sm text-brand">{errors.email}</p>}
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="service" class="field-label">Service needed</label>
          <select id="service" name="service" required class="field">
            <option value="">Select…</option>
            {company.services.map((service) => (
              <option value={service} selected={values.service === service}>{service}</option>
            ))}
          </select>
          {errors.service && <p class="mt-1 text-sm text-brand">{errors.service}</p>}
        </div>
        <div>
          <label for="cityState" class="field-label">City / state</label>
          <input id="cityState" name="cityState" type="text" required autocomplete="address-level2" value={values.cityState ?? ""} placeholder="Battle Creek, MI" class="field" />
          {errors.cityState && <p class="mt-1 text-sm text-brand">{errors.cityState}</p>}
        </div>
      </div>

      <div>
        <label for="message" class="field-label">Project details</label>
        <textarea id="message" name="message" rows="4" class="field" placeholder="Age of roof, known damage, timing, etc.">{values.message ?? ""}</textarea>
        {errors.message && <p class="mt-1 text-sm text-brand">{errors.message}</p>}
      </div>

      {errors._form && <p class="text-sm text-brand">{errors._form}</p>}

      <button type="submit" class="btn-primary w-full sm:w-auto sm:self-start">Send request</button>
      <p class="text-xs text-slate-500">
        By submitting you agree that {company.name} may contact you about your request.
      </p>
    </form>
  </div>
</section>

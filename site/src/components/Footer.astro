---
import { company } from "~/data/company";
import SocialLinks from "./SocialLinks.astro";

const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-white">
  <div class="mx-auto flex max-w-6xl flex-col gap-4 px-4 py-8 sm:flex-row sm:items-center sm:justify-between">
    <div class="text-sm text-slate-500">
      &copy; {year} {company.legalName}. All rights reserved.
      <div class="mt-1">
        <a href={company.website} class="hover:text-brand">{company.website.replace("https://", "")}</a>
      </div>
    </div>
    <SocialLinks class="text-slate-500" />
  </div>
</footer>

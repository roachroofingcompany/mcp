---
import { company } from "~/data/company";
---

<section class="bg-gradient-to-b from-white to-slate-100">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-16 md:grid-cols-2 md:items-center md:py-24">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wider text-brand">
        Serving West & Southwest Michigan
      </p>
      <h1 class="mt-3 text-4xl font-extrabold leading-tight text-ink md:text-5xl">
        {company.tagline}
      </h1>
      <p class="mt-5 text-lg text-slate-600">
        Over {company.yearsExperience}+ years of trusted roof installs, repairs, and replacements.
        Rated {company.rating.score}/5 from {company.rating.count}+ reviews.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="#quote" class="btn-primary">Get a free quote</a>
        <a href={company.phoneHref} class="btn-secondary">Call {company.phone}</a>
      </div>
    </div>
    <ul class="grid grid-cols-2 gap-3 text-sm">
      {company.services.slice(0, 8).map((service) => (
        <li class="rounded-md border border-slate-200 bg-white px-3 py-2 text-slate-700 shadow-sm">
          {service}
        </li>
      ))}
    </ul>
  </div>
</section>

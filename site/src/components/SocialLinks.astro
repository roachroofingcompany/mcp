---
import { company } from "~/data/company";

interface Props {
  class?: string;
  iconClass?: string;
}

const { class: className = "", iconClass = "h-5 w-5" } = Astro.props;
---

<div class={`flex items-center gap-3 ${className}`}>
  <a
    href={company.social.youtube}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={`${company.name} on YouTube`}
    class="text-current transition hover:text-brand"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class={iconClass}>
      <path d="M23.5 6.2a3.02 3.02 0 0 0-2.12-2.14C19.56 3.5 12 3.5 12 3.5s-7.56 0-9.38.56A3.02 3.02 0 0 0 .5 6.2 31.4 31.4 0 0 0 0 12a31.4 31.4 0 0 0 .5 5.8 3.02 3.02 0 0 0 2.12 2.14C4.44 20.5 12 20.5 12 20.5s7.56 0 9.38-.56a3.02 3.02 0 0 0 2.12-2.14A31.4 31.4 0 0 0 24 12a31.4 31.4 0 0 0-.5-5.8ZM9.75 15.5v-7l6.5 3.5-6.5 3.5Z" />
    </svg>
  </a>
  <a
    href={company.social.facebook}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={`${company.name} on Facebook`}
    class="text-current transition hover:text-brand"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class={iconClass}>
      <path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.23.2 2.23.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12Z" />
    </svg>
  </a>
</div>

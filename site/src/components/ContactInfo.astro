---
import { company } from "~/data/company";
---

<section class="bg-white">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <h2 class="text-2xl font-bold text-ink">Contact</h2>
    <p class="mt-2 text-slate-600">Prefer phone or email? Reach us directly — we answer fast.</p>

    <div class="mt-8 grid gap-6 md:grid-cols-3">
      <div class="rounded-lg border border-slate-200 p-5">
        <div class="text-sm font-semibold uppercase text-slate-500">Phone</div>
        <a href={company.phoneHref} class="mt-2 block text-xl font-bold text-brand">
          {company.phone}
        </a>
      </div>
      <div class="rounded-lg border border-slate-200 p-5">
        <div class="text-sm font-semibold uppercase text-slate-500">Email</div>
        <a href={`mailto:${company.email}`} class="mt-2 block text-xl font-bold text-brand">
          {company.email}
        </a>
      </div>
      <div class="rounded-lg border border-slate-200 p-5">
        <div class="text-sm font-semibold uppercase text-slate-500">Hours</div>
        <p class="mt-2 text-ink">{company.hours}</p>
      </div>
    </div>

    <div class="mt-10">
      <h3 class="text-lg font-semibold text-ink">Offices</h3>
      <div class="mt-4 grid gap-4 md:grid-cols-3">
        {company.offices.map((office) => (
          <div class="rounded-lg border border-slate-200 p-5">
            <div class="text-sm font-semibold uppercase text-slate-500">{office.label}</div>
            <p class="mt-2 text-ink">
              {office.street}<br />
              {office.city}, {office.state}{office.zip ? ` ${office.zip}` : ""}
            </p>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-10">
      <h3 class="text-lg font-semibold text-ink">Service areas</h3>
      <p class="mt-2 text-slate-600">{company.serviceAreas.join(" · ")}</p>
    </div>
  </div>
</section>
